[
  {
    "name": "/upload asks for the message text",
    "steps": [
      {
        "send": { "text": "/upload" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "📝 Send me the text you want to share as an ephemeral message." }
          }
        ]
      }
    ]
  },
  {
    "name": "/upload then text captures the draft",
    "steps": [
      { "send": { "text": "/upload" }, "expect": [{ "method": "sendMessage" }] },
      {
        "send": { "text": "Hello secret" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Got your message (12 characters). It's ready to be sealed." }
          }
        ]
      }
    ]
  },
  {
    "name": "plain text without /upload is not captured",
    "steps": [
      { "send": { "text": "just chatting" }, "expect": [] }
    ]
  }
]
