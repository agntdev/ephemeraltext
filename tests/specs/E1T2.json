[
  {
    "name": "oversize message is rejected",
    "steps": [
      {
        "send": {
          "text": "/upload"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": ""
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "⚠️ That message is too long (10001 characters). The maximum is 10,000 characters. Please send a shorter message and try again."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "valid message prompts for expiry mode",
    "steps": [
      {
        "send": {
          "text": "/upload"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "Hello secret"
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Got your message. How should it expire?",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    {
                      "text": "👁 First read",
                      "callback_data": "upload:mode:first-read"
                    }
                  ],
                  [
                    {
                      "text": "⏱ Time-limited",
                      "callback_data": "upload:mode:time-limited"
                    }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "selecting first-read confirms the mode",
    "steps": [
      {
        "send": {
          "text": "/upload"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "Hello secret"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "callback": "upload:mode:first-read",
          "messageId": 100
        },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "👁 This message will self-destruct after it is read once."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "selecting time-limited confirms the mode",
    "steps": [
      {
        "send": {
          "text": "/upload"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "Hello secret"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "callback": "upload:mode:time-limited",
          "messageId": 100
        },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "⏱ This message will expire after a time limit."
            }
          }
        ]
      }
    ]
  }
]
