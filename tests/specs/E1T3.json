[
  {
    "name": "message with too many links is rejected",
    "steps": [
      {
        "send": {
          "text": "/upload"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "http://a.com http://b.com http://c.com http://d.com"
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🚫 That message looks like spam and can't be shared. Please revise it and try again."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "message with a long repeated-character run is rejected",
    "steps": [
      {
        "send": {
          "text": "/upload"
        },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      },
      {
        "send": {
          "text": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "🚫 That message looks like spam and can't be shared. Please revise it and try again."
            }
          }
        ]
      }
    ]
  },
